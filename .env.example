# --- Polymarket CLOB (your trading wallet) ---
PM_HOST=https://clob.polymarket.com
PM_CHAIN_ID=137
PM_PRIVATE_KEY=
PM_FUNDER=
# 0 = direct EOA, 1 = Magic/email, 2 = browser proxy
PM_SIGNATURE_TYPE=1

# --- Public Data API (positions / activity; optional overrides) ---
# Default is Polymarket’s public host. Change only if you use a proxy or mirror.
PM_DATA_API_BASE=https://data-api.polymarket.com
# Leave empty unless your deployment injects a key (most public endpoints need none).
PM_DATA_API_KEY=

# --- Wallets to copy (set on the VPS; Hostinger env UI works the same) ---
COPY_WALLET_1=
COPY_WALLET_2=
COPY_WALLET_3=
# Optional: extra comma-separated addresses (merged with the three above).
WATCHED_WALLETS=

# --- Bot runtime ---
# activity_runner: seconds between scans (each scan pulls last 50 /activity rows per watched wallet)
POLL_INTERVAL_SECONDS=5
COPY_RATIO=1.0
BUY_SLIPPAGE_BPS=200
SELL_SLIPPAGE_BPS=200
MAX_SINGLE_ORDER_USD=100.0
MAX_TOTAL_EXPOSURE_USD=1000.0
# Set false on VPS when you are ready for live orders.
DRY_RUN=true

# Paths inside the container (keep defaults for Docker)
STATE_DIR=/app/state
WATCHLIST_FILE=/app/state/watch_wallets.json
EXECUTION_LOG=/app/state/execution_log.json

# Optional filters
ALLOWED_EVENT_SLUG_PREFIXES=
BLOCKED_CONDITION_IDS=
BLOCKED_TOKEN_IDS=
EXCLUDE_ENDED_MARKETS=true

# Activity-runner: max age (seconds) of a BUY in /activity to still copy (default 1h)
ACTIVITY_MAX_AGE_SECONDS=3600
